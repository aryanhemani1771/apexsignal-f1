# ApexSignal F1 — example environment. Copy to `.env` and fill as needed.
# The fixture-mode demo runs with ZERO credentials. Everything below is optional
# and only unlocks live/authenticated adapters.

APP_ENV=development
APP_MODE=fixture           # fixture | replay | live | paper
EXECUTION_MODE=paper       # paper | kalshi_demo | synthetic
ENABLE_LIVE_TRADING=false  # hard guard; real-money execution is not implemented

FASTF1_CACHE_DIR=.cache/fastf1

# OpenF1 real-time is optional; historical REST needs no auth.
OPENF1_USERNAME=
OPENF1_PASSWORD=

# Kalshi — demo environment only in this project.
KALSHI_ENV=demo
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Polymarket — read-only, always.
POLYMARKET_READ_ONLY=true

# News enrichment (optional).
NEWSAPI_KEY=
GDELT_API_KEY=

# LLM event extraction (optional; deterministic rule-based extractor is the default).
LLM_PROVIDER=none          # none | anthropic | openai
LLM_MODEL=
LLM_API_KEY=

DATABASE_URL=sqlite:///data/apexsignal.db
LOG_LEVEL=INFO
SIMULATION_PATHS=5000
RANDOM_SEED=42
